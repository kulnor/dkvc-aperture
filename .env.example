# Copy to .env.local and fill in.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/aperture

# Auth.js — generate with `openssl rand -base64 32`
AUTH_SECRET=

# EVE SSO OAuth2 app credentials — register at https://developers.eveonline.com/applications
AUTH_EVE_CLIENT_ID=
AUTH_EVE_CLIENT_SECRET=

# CCP requires every ESI client to identify itself.
EVE_USER_AGENT=Aperture/0.0.0 (contact@example.com)

# 32 random bytes, base64. Used to encrypt esi_access_token / esi_refresh_token at rest.
ESI_TOKEN_ENC_KEY=
