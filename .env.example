# Copy to .env.local and fill in.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/aperture

# Auth.js — generate with `openssl rand -base64 32`
AUTH_SECRET=

# EVE SSO OAuth2 app credentials — register at https://developers.eveonline.com/applications
# Set the app's callback URL to <your-origin>/api/auth/callback/eve
AUTH_EVE_CLIENT_ID=
AUTH_EVE_CLIENT_SECRET=

# EVE SSO base host. Default is Tranquility (live). For the SISI test server use
# https://sisilogin.testeveonline.com
AUTH_EVE_SSO_BASE=https://login.eveonline.com

# ESI base host. Default is the live API; the SISI test server is reached via the
# ESI_DATASOURCE constant (singularity), not a separate host.
ESI_BASE_URL=https://esi.evetech.net

# CCP requires every ESI client to identify itself. The version is read from
# package.json if this var is unset, so you only need to set it to customise
# the contact address.
# EVE_USER_AGENT=Aperture/1.0.0-alpha.1 (contact@example.com)

# 32 random bytes, base64. Used to encrypt esi_access_token / esi_refresh_token at rest.
ESI_TOKEN_ENC_KEY=

# Setup wizard
# Required in production. Gates the /setup ops console. Pick a long random string;
# rotating it invalidates active unlock cookies.
SETUP_PASSWORD=
